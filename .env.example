# URL pública do site (sem barra no final).
# Usada em todos os <meta og:*>, twitter:*, canonical e sitemap.
# DEVE bater com o domínio onde o site está realmente hospedado,
# senão o WhatsApp/Facebook/LinkedIn não conseguem carregar a imagem.
VITE_SITE_URL=https://iprotector.com.br

# Número do WhatsApp da central (formato internacional, só dígitos).
# Exemplo: 5511999999999
VITE_WHATSAPP_NUMBER=
